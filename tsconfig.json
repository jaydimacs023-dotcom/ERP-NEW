{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "App.tsx",
    "index.tsx",
    "db.ts",
    "types.ts",
    "vite.config.ts",
    "components/**/*",
    "config/**/*",
    "services/**/*",
    "utils/**/*",
    "views/**/*",
    "vite/types/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src",
    "supabase",
    "tests"
  ]
}
